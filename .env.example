# ─── MIDAS Environment Variables ─────────
# Bu faylni .env ga nusxalang va to'ldiring
# cp .env.example .env

# ─── Database ─────────────────────────────
DATABASE_URL=postgresql://midas_user:your_password@localhost:5432/midas_db
POSTGRES_PASSWORD=your_strong_password

# ─── Redis ────────────────────────────────
REDIS_URL=redis://:your_redis_password@localhost:6379
REDIS_PASSWORD=your_redis_password

# ─── JWT ──────────────────────────────────
# Kamida 64 belgili random string
# Generatsiya: openssl rand -base64 64
JWT_SECRET=your_super_secret_jwt_key_at_least_64_chars_long

# ─── Telegram ─────────────────────────────
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
WEBHOOK_DOMAIN=https://api.midas.uz
WEBHOOK_SECRET_TOKEN=your_webhook_secret_token
MINIAPP_URL=https://app.midas.uz
ADMIN_URL=https://admin.midas.uz

# ─── OpenAI ───────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Payme ────────────────────────────────
PAYME_MERCHANT_ID=your_payme_merchant_id
PAYME_SECRET_KEY=your_payme_secret_key
PAYME_TEST_MODE=true  # Productiondan oldin false qiling

# ─── Click ────────────────────────────────
CLICK_MERCHANT_ID=your_click_merchant_id
CLICK_SERVICE_ID=your_click_service_id
CLICK_SECRET_KEY=your_click_secret_key
CLICK_TEST_MODE=true

# ─── App ──────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

# ─── pgAdmin (optional, dev tools) ────────
PGADMIN_PASSWORD=admin123
