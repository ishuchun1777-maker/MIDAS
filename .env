# ═══════════════════════════════════════════════
# MIDAS — Railway Production Sinov .env
# ═══════════════════════════════════════════════
# MUHIM: Quyidagi 2 ta qiymatni O'ZINGIZNIKI bilan almashtiring:
#   BOT_TOKEN      — @BotFather dan olingan token
#   OPENAI_API_KEY — platform.openai.com dan olingan key
# ═══════════════════════════════════════════════

# ─── Database (Railway avtomatik beradi) ───────
# Railway PostgreSQL servisidan nusxalab qo'ying:
DATABASE_URL=postgresql://postgres:RAILWAY_BERADI@RAILWAY_BERADI.railway.app:5432/railway

# ─── Redis (Railway avtomatik beradi) ──────────
# Railway Redis servisidan nusxalab qo'ying:
REDIS_URL=redis://default:RAILWAY_BERADI@RAILWAY_BERADI.railway.app:6379

# ─── JWT (tayyor, o'zgartirmang) ───────────────
JWT_SECRET=3aQkGoxDjCs9XCYouRAX/WFJ01KYFclUOKu5lZkrYjezpFuon7reRXHd9fCis7XZ

# ─── Telegram Bot ──────────────────────────────
# @BotFather → /newbot → token nusxalab qo'ying
BOT_TOKEN=SИЗNING_BOT_TOKEN_INI_YOZING

# Webhook domain (Railway API servis URLi)
# Railway → API servis → Settings → Domain dan nusxalab qo'ying
# Masalan: https://midas-api-production.up.railway.app
WEBHOOK_DOMAIN=https://RAILWAY_API_URL.up.railway.app
WEBHOOK_SECRET_TOKEN=c584352764aa8296c7db564d4f3f526950b2be39

# ─── Mini App & Admin URL ──────────────────────
# Railway → miniapp servis → Settings → Domain
MINIAPP_URL=https://RAILWAY_MINIAPP_URL.up.railway.app
ADMIN_URL=https://RAILWAY_ADMIN_URL.up.railway.app

# ─── OpenAI ────────────────────────────────────
# platform.openai.com → API keys → Create new secret key
OPENAI_API_KEY=SIZNING_OPENAI_KEY_INGIZNI_YOZING

# ─── Internal secret (tayyor, o'zgartirmang) ───
INTERNAL_SECRET=4c3001ffa9cc0e8195d3a4ca1afeedac7676763505a3e6a91146bffd41d15a1f

# ─── To'lov (hozircha o'chirilgan — sinov uchun) ─
PAYME_MERCHANT_ID=test_placeholder
PAYME_SECRET_KEY=test_placeholder
PAYME_TEST_MODE=true
CLICK_MERCHANT_ID=test_placeholder
CLICK_SERVICE_ID=test_placeholder
CLICK_SECRET_KEY=test_placeholder
CLICK_TEST_MODE=true

# ─── App ───────────────────────────────────────
NODE_ENV=production
PORT=3001
LOG_LEVEL=info
